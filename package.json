{
    "name": "atomize",
    "private": true,
    "type": "module",
    "packageManager": "bun@1.2.5",
    "scripts": {
        "dev": "vite",
        "android": "bun run scripts/godot/export-mobile.ts android",
        "ios": "scripts/godot/ios.sh",
        "ios:build": "bash scripts/godot/ios-build.sh",
        "ios:export": "bun run scripts/godot/export-mobile.ts ios",
        "ios:run": "bash scripts/godot/ios-run-device.sh",
        "godot:fixtures": "bun run scripts/godot/generate-core-fixtures.ts",
        "godot:open": "bun run scripts/godot/open-project.ts",
        "godot:test": "bun run godot:fixtures && bun run scripts/godot/run-core-parity.ts",
        "prebuild": "tsc -p tsconfig.json --noEmit",
        "build": "vite build",
        "lint": "eslint ."
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css,html,yml,yaml}": "prettier --write"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/node": "^25.5.0",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react-swc": "^3.8.0",
        "eslint": "^10.0.3",
        "eslint-config-complete": "^4.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "typescript": "^5.8.2",
        "vite": "^6.2.0",
        "vite-plugin-pwa": "^0.21.1"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.49.4",
        "@vercel/analytics": "^2.0.1",
        "lucide-react": "^0.577.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "workbox-window": "^7.3.0"
    }
}
